{
	"name": "Ingestion_Customer_JOIN_ADLS",
	"properties": {
		"activities": [
			{
				"name": "Copy data1",
				"type": "Copy",
				"dependsOn": [],
				"policy": {
					"timeout": "0.12:00:00",
					"retry": 0,
					"retryIntervalInSeconds": 30,
					"secureOutput": false,
					"secureInput": false
				},
				"userProperties": [],
				"typeProperties": {
					"source": {
						"type": "AzureSqlSource",
						"sqlReaderQuery": "SELECT\n    C.CustomerID,\n    C.FirstName,\n    C.LastName,\n    A.AddressLine1,\n    A.AddressLine2,\n    A.City,\n    A.StateProvince,\n    A.PostalCode,\n    A.CountryRegion\nFROM SalesLT.Customer C\nINNER JOIN SalesLT.CustomerAddress CA\n    ON C.CustomerID = CA.CustomerID\nINNER JOIN SalesLT.Address A\n    ON CA.AddressID = A.AddressID;",
						"queryTimeout": "02:00:00",
						"partitionOption": "None"
					},
					"sink": {
						"type": "DelimitedTextSink",
						"storeSettings": {
							"type": "AzureBlobFSWriteSettings"
						},
						"formatSettings": {
							"type": "DelimitedTextWriteSettings",
							"quoteAllText": true,
							"fileExtension": ".txt"
						}
					},
					"enableStaging": false,
					"translator": {
						"type": "TabularTranslator",
						"typeConversion": true,
						"typeConversionSettings": {
							"allowDataTruncation": true,
							"treatBooleanAsNumber": false
						}
					}
				},
				"inputs": [
					{
						"referenceName": "Customerdb",
						"type": "DatasetReference"
					}
				],
				"outputs": [
					{
						"referenceName": "CustomerAddress",
						"type": "DatasetReference"
					}
				]
			}
		],
		"annotations": [],
		"lastPublishTime": "2026-07-01T05:46:02Z"
	},
	"type": "Microsoft.DataFactory/factories/pipelines"
}