						"File": "Product.csv"
					},
					{
						"Query": "SELECT * FROM SalesLT.Customer WHERE CustomerID > 100 AND CustomerID < 1000",
						"Folder": "Customer",
						"File": "Customer.csv"
					}
				]
			}
		},
