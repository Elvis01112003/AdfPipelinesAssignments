			"type": "secureString",
			"metadata": "Secure string for 'accountKey' of 'ADLS'"
		},
		"SalesDatabase_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'SalesDatabase'"
		},
		"ADLS_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://elvis01112003adls.dfs.core.windows.net/"
